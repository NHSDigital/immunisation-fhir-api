FROM python:3.13-alpine

# Install system dependencies needed for building Python packages
RUN apk add --no-cache gcc musl-dev libffi-dev openssl-dev python3-dev

# Install Poetry
RUN pip install poetry==1.8.4

WORKDIR /app

# Copy only poetry files first for better caching of dependencies
COPY pyproject.toml poetry.lock ./

# Install Python dependencies (from poetry.lock)
RUN poetry install --no-root

# Copy the rest of the code
COPY . .

# Optionally, set a default command (can be overridden in docker run)
CMD ["poetry", "run", "python", "-m", "unittest", "discover"]